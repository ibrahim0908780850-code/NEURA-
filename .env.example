# ==================================
# NEURA-1 Environment Configuration
# ==================================

# Application
APP_NAME=NEURA-1
APP_VERSION=0.5.0
ENVIRONMENT=production


# Model Configuration
BASE_MODEL=Qwen
MODEL_NAME=Qwen/Qwen3.5-9B


# API Server
HOST=0.0.0.0
PORT=8000


# Cloud Provider
CLOUD_PROVIDER=huggingface


# Database
# Future: PostgreSQL / Supabase / Vector Database
DATABASE_URL=your_database_url


# Hugging Face
HF_TOKEN=hf_your_token_here


# External Model Provider
MODEL_API_KEY=


# Memory System
MEMORY_ENABLED=true


# Knowledge Base
KNOWLEDGE_ENABLED=true


# Tools System
TOOLS_ENABLED=true


# Web Search
WEB_SEARCH_ENABLED=true
TAVILY_API_KEY=your_tavily_key_here


# Code Agent
CODE_AGENT_ENABLED=true