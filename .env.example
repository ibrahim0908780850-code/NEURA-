# ==================================
# NEURA-1 Environment Configuration
# ==================================

# Application
APP_NAME=NEURA-1
APP_VERSION=0.5.0
ENVIRONMENT=production

# Model Configuration
BASE_MODEL=Qwen
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# API Server
HOST=0.0.0.0
PORT=8000

# Cloud Provider
CLOUD_PROVIDER=your_provider

# Database
# Future: PostgreSQL / Supabase / Vector Database
DATABASE_URL=your_database_url

# Hugging Face
HF_TOKEN=your_huggingface_token

# External Model Provider (Optional)
MODEL_API_KEY=your_model_api_key

# Memory System
MEMORY_ENABLED=true

# Knowledge Base
KNOWLEDGE_ENABLED=true

# Tools System
TOOLS_ENABLED=true